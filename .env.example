# このファイルを .env にコピーして各APIキーを設定してください
# cp .env.example .env
#
# .env はGitにコミットされません (.gitignore に記載済み)
# APIキーは絶対にコードに直接書かないでください

# Anthropic (Claude)
# https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# https://aistudio.google.com/app/apikey で取得
GEMINI_API_KEY=AIza...

# OpenRouter (複数モデルを統合利用)
# https://openrouter.ai/keys で取得
OPENROUTER_API_KEY=sk-or-...

# デフォルトプロバイダーの変更 (省略時: anthropic)
# EXCEL_AGENT_PROVIDER=gemini

# デフォルトモデルの変更
# EXCEL_AGENT_MODEL=gemini-2.0-flash
